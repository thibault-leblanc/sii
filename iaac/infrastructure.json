      }
    },
    "api-rincage": {
      "type": "conteneur_docker",
      "nom": "api-rincage",
      "fonction": "Automate logique de contrôle et serveur OPC-UA",
      "depot_source": "https://github.com/thibault-leblanc/sii/tree/main/configurations/conteneurs/api/rincage",
      "chemin_deploiement": "api/rincage",
      "reseau_virtuel": {
        "type": "macvlan_multiple",
        "attachement_hote": "eth0",
        "interfaces": {
          "interface_terrain": { "vlan_cible": "VLAN20", "ip_statique": "192.168.20.20" },
          "interface_scada": { "vlan_cible": "VLAN30", "ip_statique": "192.168.30.20" }
        }
      }
    }
